# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example is intentionally committed
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client
/src/generated/

# playwright
/playwright-report/
/test-results/

# uploads (handled by docker volume in production)
/public/uploads/*
!/public/uploads/.gitkeep

# Claude Code local settings (personal permissions, not for the repo)
.claude/settings.local.json
