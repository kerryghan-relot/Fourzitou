generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SuggestionType {
  BUG
  IDEA
  OTHER
}

enum SuggestionReaction {
  UP
  DOWN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  displayName  String    @unique
  avatarPath   String?
  locale       String    @default("en")
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ownedTopics Topic[]       @relation("TopicOwner")
  memberships TopicMember[]
  items       Item[]
  scores      Score[]
  comments    Comment[]
  suggestions Suggestion[]
}

model Topic {
  id         String   @id @default(cuid())
  ownerId    String
  title      String
  titleColor String   @default("#ffffff")
  emoji      String   @default("📋")
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner   User          @relation("TopicOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members TopicMember[]
  items   Item[]
}

model TopicMember {
  topicId String
  userId  String

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([topicId, userId])
}

model Item {
  id          String   @id @default(cuid())
  topicId     String
  creatorId   String
  title       String
  description String
  imagePath   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic    Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  creator  User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  scores   Score[]
  comments Comment[]
}

model Score {
  itemId String
  userId String
  stars  Int     @default(0)
  crown  Boolean @default(false)
  poop   Boolean @default(false)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([itemId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  itemId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Suggestion {
  id          String              @id @default(cuid())
  type        SuggestionType
  title       String
  description String
  imagePath   String?
  removed     Boolean             @default(false)
  reaction    SuggestionReaction?
  userId      String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
